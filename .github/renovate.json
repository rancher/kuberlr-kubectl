{
  "extends": [
    "github>rancher/renovate-config#release"
  ],
  "baseBranchPatterns": [
    "main",
    "release/v7.x",
    "release/v6.x",
    "release/v5.x",
    "release/v4.x",
    "release/v3.x"
  ],
  "prHourlyLimit": 24,
  "packageRules": [
    {
      "matchBaseBranches": ["main"],
      "extends": ["github>rancher/renovate-config:rancher-main#main"]
    },
    {
      "matchBaseBranches": ["release/v7.x"],
      "extends": ["github>rancher/renovate-config:rancher-2.14#main"]
    },
    {
      "matchBaseBranches": ["release/v6.x"],
      "extends": ["github>rancher/renovate-config:rancher-2.13#main"]
    },
    {
      "matchBaseBranches": ["release/v5.x"],
      "extends": ["github>rancher/renovate-config:rancher-2.12#main"]
    },
    {
      "description": "Using allowedVersions ensures that the upstream range does not block patch bumps.",
      "matchDepNames": [
        "kubernetes/kubernetes"
      ],
      "separateMinorPatch": true,
      "allowedVersions": ">=1.28.0"
    },
    {
      "description": "Disable major and minor updates",
      "matchDepNames": [
        "kubernetes/kubernetes"
      ],
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "enabled": false
    },
    {
      "groupName": "GitHub Workflow Actions",
      "groupSlug": "gha-deps",
      "matchManagers": [
        "github-actions"
      ]
    },
    {
      "groupName": "Docker File Deps",
      "groupSlug": "docker-bumps",
      "matchManagers": [
        "dockerfile"
      ]
    },
    {
      "groupName": "Kubectl Dep Versions",
      "groupSlug": "kubectl-bumps",
      "matchDepNames": [
        "kubernetes/kubernetes"
      ]
    }
  ]
}
